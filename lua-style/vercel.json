{
  "version": 2,
  "builds": [
    {
      "src": "api/review.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/lua-style/api/review(\\.php)?$", "dest": "/api/review.js" },
    { "src": "/lua-style/?$", "dest": "/index.html" },
    { "src": "/lua-style/(.*)", "dest": "/$1" },
    { "src": "/api/review(\\.php)?$", "dest": "/api/review.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
